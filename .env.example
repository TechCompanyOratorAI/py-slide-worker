# ============================================
# Environment Variables for py-analysis-worker
# ============================================
# Copy this file to .env and fill in your actual values

# --------------------------------------------
# AWS Configuration (Required)
# --------------------------------------------
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# --------------------------------------------
# SQS Queue Configuration (Required)
# --------------------------------------------
# URL của SQS queue cho slides processing
# Format: https://sqs.{region}.amazonaws.com/{account-id}/{queue-name}
AWS_SQS_SLIDES_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/123456789012/slides-queue

# --------------------------------------------
# Webhook Configuration (Required)
# --------------------------------------------
# URL của Node API webhook endpoint
WEBHOOK_URL=http://localhost:3000/api/v1/webhooks/slides-complete

# Secret key để authenticate webhook requests
# Phải khớp với WEBHOOK_SECRET trong Node API service
WEBHOOK_SECRET=your_webhook_secret_here

# --------------------------------------------
# OCR Configuration (Optional - for future implementation)
# --------------------------------------------
# Path to tesseract binary (nếu dùng pytesseract)
# Linux: /usr/bin/tesseract
# macOS: /usr/local/bin/tesseract (hoặc /opt/homebrew/bin/tesseract nếu dùng Apple Silicon)
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSERACT_CMD=/usr/bin/tesseract

# Languages for OCR (ví dụ: vie+eng cho tiếng Việt và tiếng Anh)
# OCR_LANGUAGE=vie+eng

# --------------------------------------------
# Embedding Model Configuration (Optional - for future implementation)
# --------------------------------------------
# Model name cho sentence-transformers
# Ví dụ: paraphrase-multilingual-MiniLM-L12-v2 (hỗ trợ đa ngôn ngữ)
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --------------------------------------------
# Logging Configuration (Optional)
# --------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Path to log file (nếu muốn log ra file)
# LOG_FILE=logs/worker.log

# --------------------------------------------
# Processing Configuration (Optional)
# --------------------------------------------
# Maximum number of retries khi xử lý slide thất bại
# MAX_RETRIES=3

# Timeout cho webhook request (seconds)
# WEBHOOK_TIMEOUT=30

# --------------------------------------------
# Development/Testing (Optional)
# --------------------------------------------
# Set to 'true' để enable debug mode
# DEBUG=false

# Mock mode - không thực sự xử lý slides, chỉ log (cho testing)
# MOCK_MODE=false
